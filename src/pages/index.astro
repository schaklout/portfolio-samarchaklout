---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/cards/ProjectCard.astro';
import Badge from '../components/ui/Badge.astro';

// Lógica de Fetch igual que antes...
const response = await fetch('https://api.github.com/users/schaklout/repos?sort=updated');
const repos = await response.json();
---

<Layout title="Samar Chaklout | Cloud & Fullstack">
  <!-- Hero e Info aquí... -->
  
  <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
     <!-- Bento Items -->
     <div class="col-span-2 bg-zinc-900/50 p-8 rounded-3xl border border-zinc-800">
        <Badge variant="orange">Experiencia</Badge>
        <h2 class="text-2xl font-bold mt-4 text-white">Idirecto Mayoristas</h2>
        <p class="text-zinc-400 mt-2">Arquitectura ERP y optimización PHP/MySQL.</p>
     </div>
  </section>

  <section class="mt-20">
    <h2 class="text-3xl font-bold text-white mb-10">Proyectos</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {repos.slice(0, 6).map((repo: any) => <ProjectCard repo={repo} />)}
    </div>
  </section>
</Layout>