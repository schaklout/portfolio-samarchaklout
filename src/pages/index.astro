---
import Layout from '../layouts/Layout.astro';

const userRes = await fetch('https://api.github.com/users/schaklout');
const user = await userRes.json();
const reposRes = await fetch('https://api.github.com/users/schaklout/repos?sort=updated');
const repos = await reposRes.json();

const skills = {
  dev: ["PHP", "JavaScript", "Java", "MySQL", "Angular", "Codeigniter"],
  cloud: ["AWS Technical Essentials", "Cloud Computing", "AWS Practitioner (In Progress)"]
};
---

<Layout title="Samar Chaklout | Cloud & Dev Portfolio">
	<main class="max-w-4xl mx-auto px-6 py-16">
		<header class="flex flex-col md:flex-row items-center gap-10 mb-20">
			<img src={user.avatar_url} class="w-32 h-32 rounded-full border-2 border-orange-500 p-1 bg-zinc-900 shadow-xl shadow-orange-500/10" alt="Samar" />
			<div class="text-center md:text-left">
				<h1 class="text-4xl font-bold text-white tracking-tight leading-tight italic">{user.name || "Samar Chaklout"}</h1>
				<p class="text-orange-500 font-mono text-xs mt-2 uppercase tracking-[0.3em]">Fullstack Developer // AWS Enthusiast</p>
				<p class="mt-4 text-zinc-400 text-sm max-w-lg leading-relaxed">
					Técnico Superior en DAW y cursando DAM. Experiencia en PHP y MySQL en entornos empresariales, actualmente enfocada en <span class="text-white border-b border-orange-500/50">Cloud Computing</span>.
				</p>
			</div>
		</header>

		<section class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">
			<div class="p-6 bg-zinc-900/30 border border-zinc-800 rounded-2xl">
				<h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-orange-500 rounded-full"></span> Tech Stack
                </h3>
				<div class="flex flex-wrap gap-2">
					{skills.dev.map(s => <span class="text-[10px] font-mono bg-zinc-800/50 px-2 py-1 rounded text-zinc-400 border border-zinc-700/30">{s}</span>)}
				</div>
			</div>
			<div class="p-6 bg-orange-500/5 border border-orange-500/20 rounded-2xl">
				<h3 class="text-orange-500 font-semibold mb-4 text-sm uppercase tracking-wider flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-orange-500 rounded-full"></span> Cloud AWS
                </h3>
				<div class="flex flex-wrap gap-2">
					{skills.cloud.map(s => <span class="text-[10px] font-mono bg-orange-500/10 text-orange-200 px-2 py-1 rounded border border-orange-500/20">{s}</span>)}
				</div>
			</div>
		</section>

		<section>
			<h2 class="text-lg font-bold text-white mb-8 border-l-2 border-orange-500 pl-4 uppercase tracking-widest">Repositorios</h2>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
				{repos.filter((r:any) => !r.fork).slice(0,4).map((repo:any) => (
					<a href={repo.html_url} target="_blank" class="p-6 bg-[#0a0a0a] border border-zinc-900 rounded-xl hover:bg-zinc-900/40 hover:border-orange-500/30 transition-all group">
						<div class="flex justify-between items-start mb-3">
							<h4 class="text-zinc-200 font-bold group-hover:text-orange-500 transition-colors">{repo.name}</h4>
							<span class="text-[9px] font-mono text-zinc-600 border border-zinc-800 px-1 py-0.5 rounded">{repo.language || 'Code'}</span>
						</div>
						<p class="text-xs text-zinc-500 line-clamp-2 leading-relaxed italic italic">{repo.description || "Desarrollo de aplicación web dinámica."}</p>
					</a>
				))}
			</div>
		</section>

		<footer class="mt-32 pt-8 border-t border-zinc-900 text-center text-zinc-600 text-[10px] uppercase tracking-[0.2em]">
			<p>Data-driven Portfolio // 2026 // Samar Chaklout</p>
		</footer>
	</main>
</Layout>
